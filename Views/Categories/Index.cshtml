@model IEnumerable<WebsiteBanHang.Models.Category>

<h2 class="mb-4">📚 Danh mục sách</h2>

<a asp-action="Add" class="btn btn-success mb-3">
    + Thêm danh mục
</a>

<table class="table table-bordered table-hover shadow">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tên danh mục</th>
            <th width="250">Chức năng</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>

                <td>
                    <b>@item.Name</b>
                </td>

                <td>
                    <a asp-action="Display" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                        Xem
                    </a>

                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                        Sửa
                    </a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                        Xóa
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>