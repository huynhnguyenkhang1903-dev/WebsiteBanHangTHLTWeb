@model WebsiteBanHang.Models.Product

<h2>Chi Tiết Sản Phẩm</h2>

<h3>@Model.Name</h3>

<img src="@Model.ImageUrl" width="200" />

<p><b>Giá:</b> @Model.Price</p>

<p><b>Mô tả:</b> @Model.Description</p>

<p><b>Loại:</b> @Model.Category?.Name</p>

<a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary">
    Chỉnh sửa
</a>

<a asp-action="Index" class="btn btn-secondary">
    Quay lại danh sách
</a>