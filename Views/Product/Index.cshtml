@model IEnumerable<WebsiteBanHang.Models.Product>

<h2>Products</h2>

<a asp-action="Add" class="btn btn-success mb-3">Thêm sản phẩm</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Tên</th>
            <th>Giá</th>
            <th>Mô tả</th>
            <th>Ảnh sản phẩm</th>
            <th>Loại</th>
            <th>Chức năng</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.Description</td>

                <td>
                    <img src="@item.ImageUrl" width="80" />
                </td>

                <td>@item.Category?.Name</td>

                <td>
                    <a asp-action="Display" asp-route-id="@item.Id" class="btn btn-primary">View</a>

                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>

                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>