@model IEnumerable<WebsiteBanHang.Models.Product>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">

        <h2 class="fw-bold mb-2 mb-md-0">📚 Danh sách sách</h2>

        <!-- Form tìm kiếm -->
        <form class="d-flex mb-2 mb-md-0" asp-controller="Product" asp-action="Index" method="get">
            <input class="form-control me-2" type="search" name="searchString" placeholder="Tìm sách..." value="@ViewData["CurrentFilter"]" />
            <button class="btn btn-outline-primary" type="submit">🔍 Tìm</button>
        </form>

        <!-- Nút Thêm sản phẩm -->
        <a asp-controller="Product"
           asp-action="Add"
           class="btn btn-success ms-2">
            ➕ Thêm sản phẩm
        </a>

    </div>

    <div class="row mt-3">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4" data-aos="zoom-in">
                <div class="card book-card h-100 shadow-sm">
                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name">
                    <div class="card-body text-center">
                        <h6 class="fw-bold">@item.Name</h6>
                        <p class="text-danger fw-bold">
                            @item.Price.ToString("N0") đ
                        </p>
                        <a asp-controller="Product"
                           asp-action="Display"
                           asp-route-id="@item.Id"
                           class="btn btn-primary btn-sm">
                            Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

</div>