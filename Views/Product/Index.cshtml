@model IEnumerable<WebsiteBanHang.Models.Product>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">

        <h2 class="fw-bold mb-2 mb-md-0">📚 Danh sách sách</h2>

        <!-- Form tìm kiếm -->
        <form class="d-flex mb-2 mb-md-0" asp-controller="Product" asp-action="Index" method="get">
            <input class="form-control me-2"
                   type="search"
                   name="searchString"
                   placeholder="Tìm sách..."
                   value="@ViewData["CurrentFilter"]" />

            <button class="btn btn-outline-primary" type="submit">
                🔍 Tìm
            </button>
        </form>

        <!-- 👑 Chỉ ADMIN mới thấy -->
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Product"
               asp-action="Add"
               class="btn btn-success ms-2">
                ➕ Thêm sản phẩm
            </a>
        }

    </div>

    <div class="row mt-3">
        @foreach (var item in Model)
        {
            <div class="col-md-3 mb-4" data-aos="zoom-in">
                <div class="card book-card h-100 shadow-sm">

                    <!-- FIX NULL IMAGE -->
                    <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/no-image.png" : item.ImageUrl)"
                         class="card-img-top"
                         style="height:250px; object-fit:cover;"
                         alt="@item.Name">

                    <div class="card-body text-center">

                        <h6 class="fw-bold">@item.Name</h6>

                        <p class="text-danger fw-bold">
                            @item.Price.ToString("N0") đ
                        </p>

                        <!-- Xem chi tiết -->
                        <a asp-controller="Product"
                           asp-action="Display"
                           asp-route-id="@item.Id"
                           class="btn btn-primary btn-sm mb-2">
                            👁 Xem
                        </a>

                        <!-- 🛒 ADD TO CART -->
                        <a asp-controller="Cart"
                           asp-action="AddToCart"
                           asp-route-productId="@item.Id"
                           class="btn btn-outline-dark btn-sm">
                            🛒 Thêm vào giỏ
                        </a>

                    </div>
                </div>
            </div>
        }
    </div>

</div>