@page
@model WebsiteBanHang.Areas.Identity.Pages.Account.RegisterModel

<style>
    .auth-wrapper {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        width: 100%;
        max-width: 450px;
        border-radius: 12px;
    }
</style>

<div class="auth-wrapper">

    <div class="card p-4 shadow auth-card">

        <div class="text-center mb-3">
            <img src="https://cdn-icons-png.flaticon.com/512/2436/2436636.png" width="70" />
            <h4 class="mt-2 fw-bold">Đăng ký</h4>
        </div>

        <form method="post">

            <div class="mb-3">
                <label class="form-label">Họ tên</label>
                <input asp-for="Input.FullName" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>
                <input asp-for="Input.Password" type="password" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Địa chỉ</label>
                <input asp-for="Input.Address" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Tuổi</label>
                <input asp-for="Input.Age" type="number" class="form-control" />
            </div>

            <button class="btn btn-success w-100">
                Đăng ký
            </button>

            <div class="text-danger text-center mt-2">
                @foreach (var error in Model.Errors)
                {
                    <p>@error</p>
                }
            </div>

            <hr />

            <div class="text-center">
                <a href="/Identity/Account/Login">Đã có tài khoản?</a>
            </div>

        </form>

    </div>

</div>