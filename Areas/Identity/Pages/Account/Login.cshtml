@page
@model WebsiteBanHang.Areas.Identity.Pages.Account.LoginModel

<style>
    .auth-wrapper {
        min-height: calc(100vh - 80px);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-card {
        width: 100%;
        max-width: 400px;
        border-radius: 12px;
    }
</style>

<div class="auth-wrapper">

    <div class="card p-4 shadow auth-card">

        <div class="text-center mb-3">
            <img src="https://cdn-icons-png.flaticon.com/512/29/29302.png" width="70" />
            <h4 class="mt-2 fw-bold">Đăng nhập</h4>
        </div>

        <form method="post">

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Mật khẩu</label>
                <input asp-for="Input.Password" type="password" class="form-control" />
            </div>

            <button class="btn btn-primary w-100">
                Đăng nhập
            </button>

            <div class="text-danger text-center mt-2">
                @Model.ErrorMessage
            </div>

            <hr />

            <div class="text-center">
                <a href="/Identity/Account/Register">Tạo tài khoản</a>
            </div>

        </form>

    </div>

</div>