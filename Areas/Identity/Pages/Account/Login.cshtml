@page
@model WebsiteBanHang.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="container mt-5">
    <div class="row shadow-lg rounded overflow-hidden">

        <!-- Hình minh họa -->
        <div class="col-md-6 d-none d-md-flex align-items-center justify-content-center bg-light">
            <img src="https://cdn-icons-png.flaticon.com/512/29/29302.png" width="200" />
        </div>

        <!-- Form -->
        <div class="col-md-6 p-5">

            <h3 class="text-center mb-4">
                📚 Đăng nhập cửa hàng sách
            </h3>

            <form method="post">

                <div class="form-group mb-3">
                    <label>Email</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="Nhập email">
                </div>

                <div class="form-group mb-4">
                    <label>Mật khẩu</label>
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Nhập mật khẩu">
                </div>

                <button type="submit" class="btn btn-primary w-100">
                    Đăng nhập
                </button>

                <div class="text-danger mt-3">
                    @Model.ErrorMessage
                </div>

                <hr>

                <div class="text-center">
                    Chưa có tài khoản?
                    <a href="/Identity/Account/Register">
                        Đăng ký ngay
                    </a>
                </div>

            </form>
        </div>

    </div>
</div>